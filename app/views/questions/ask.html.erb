<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4 p-md-5">
          <h1 class="text-center fw-bold mb-3">Stupid Coaching</h1>
          <p class="text-center text-muted mb-4">Ask your coach a question</p>

          <form action="/answer" method="get" data-turbo="false">
            <label for="question" class="form-label fw-semibold">Your question</label>

            <div class="input-group input-group-lg mb-3">
              <input
                type="text"
                id="question"
                name="question"
                class="form-control"
                placeholder="Type your question here">

              <input
                type="submit"
                value="Ask!"
                class="btn btn-primary">
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
