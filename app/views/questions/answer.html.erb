<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4 p-md-5">

          <h1 class="text-center fw-bold mb-4">Stupid Coaching</h1>

          <div class="mb-4 p-3 bg-light rounded-4 border">
            <p class="mb-1 fw-semibold text-secondary">You asked:</p>
            <p class="mb-0 fs-5"><%= @question %></p>
          </div>

          <div class="mb-4 p-3 rounded-4 border border-warning bg-warning-subtle">
            <p class="mb-1 fw-semibold text-secondary">Coach says:</p>
            <p class="mb-0 fs-5"><%= @answer %></p>
          </div>

          <div class="d-grid">
            <a href="/ask" class="btn btn-primary btn-lg rounded-3">
              Ask another question
            </a>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
